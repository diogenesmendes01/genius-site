# ───────────────────────────────────────
# Server
# ───────────────────────────────────────
PORT=3120
HOST=0.0.0.0
NODE_ENV=development

# Comma-separated list of allowed origins for CORS.
# In prod: https://geniusidiomas.com,https://www.geniusidiomas.com
ALLOWED_ORIGINS=http://localhost:3120

# ───────────────────────────────────────
# Q10 (Jack) API
# ───────────────────────────────────────
Q10_API_KEY=your-q10-subscription-key
Q10_BASE_URL=https://api.q10.com/v1

# Set to "true" to bypass real Q10 API and use realistic mock data
# (useful for local dev and demos without burning the Q10 quota).
Q10_MOCK=false

# Dashboard cache TTL in seconds (default 300 = 5min)
Q10_CACHE_TTL=300

# ───────────────────────────────────────
# Dashboard Auth (JWT + bcrypt)
# ───────────────────────────────────────
# Secret for signing dashboard login JWTs. MUST be set to a long random string.
# Generate one: openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-secret

# Session lifetime (minutes). Cookie expires; user must log in again.
JWT_EXPIRES_MINUTES=480

# First admin user — seeded on startup if no users exist in the DB.
# Change these before first deploy. After the first run the DB holds the hash.
ADMIN_EMAIL=admin@geniusidiomas.com
ADMIN_PASSWORD=change-me-on-first-run
ADMIN_NAME=Administrador

# ───────────────────────────────────────
# Database (SQLite file)
# ───────────────────────────────────────
# Path to the SQLite file. In Coolify mount a persistent volume at /data.
DATABASE_PATH=./data/genius.sqlite

# ───────────────────────────────────────
# Email (Gmail) — used by the leads form
# ───────────────────────────────────────
# 1. https://myaccount.google.com/apppasswords
# 2. Create an App Password for this app
# 3. Use that password here (not your normal Gmail password)
EMAIL_USER=
EMAIL_PASS=
